{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src"],
  "//exclude": "Dead code from the dubbing/subtitle features — kept on disk but not wired into the app. transcript is now used by the script-based separation flow, so it's typechecked.",
  "exclude": [
    "src/routes/subtitle.ts",
    "src/routes/dubbing.ts",
    "src/jobs/subtitleJob.ts",
    "src/jobs/dubbingJob.ts",
    "src/gemini/geminiClient.ts",
    "src/util/srt.ts"
  ]
}
