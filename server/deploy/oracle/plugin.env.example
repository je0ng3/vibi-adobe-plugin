# vibi-adobe-plugin server — Oracle VM 런타임 env. 이 파일을 plugin.env 로 복사 후 모두 채우기.
#   cp plugin.env.example plugin.env && vim plugin.env
# plugin.env 는 절대 commit 금지 (.gitignore 에 deploy/oracle/plugin.env 추가됨).
# 값 출처: 기존 로컬 server/.env 운영값을 그대로 옮기되, 아래 production 항목만 교체.

# --- Server (필수)
# production 이어야 startup 안전가드 동작(ALLOWED_ORIGINS 비었거나 AUTH_DEV_BYPASS=true 면 부팅 거부).
NODE_ENV=production
PORT=8787
# 공개 https 도메인. Caddyfile 의 도메인 / Google OAuth redirect / Paddle webhook 의 base 와 동일.
PUBLIC_BASE_URL=https://plugin-api.vibi.fm
# /api/* 를 호출하는 브라우저 origin 화이트리스트(쉼표 구분). production 필수.
# 호스팅 device/checkout 페이지가 같은 호스트에서 뜨므로 보통 자기 자신 + 랜딩.
ALLOWED_ORIGINS=https://plugin-api.vibi.fm,https://vibi.fm

# --- Auth (필수)
JWT_SECRET=
# Google OAuth (Authorization Code). 콘솔 redirect URI 에 다음을 등록:
#   https://plugin-api.vibi.fm/api/v2/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# production 에서는 반드시 false (true 면 부팅 거부됨).
AUTH_DEV_BYPASS=false

# --- Database (PostgreSQL — Neon/Supabase 등 관리형 그대로 재사용, 컴퓨트만 Oracle 로)
DATABASE_URL=
# 관리형 Postgres 는 TLS 필수 → true. Neon 인증서는 공개 신뢰됨 → NO_VERIFY 는 false 유지.
DATABASE_SSL=true
DATABASE_SSL_NO_VERIFY=false
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000

# --- Credits
SIGNUP_BONUS_CREDITS=10
# 컨테이너 tmpfs 경로 — compose 가 /tmp/stems 로 고정 주입(여기서 비워도 됨).
STEM_DIR=/tmp/stems
JOB_TTL_MS=3600000
JOB_SWEEP_INTERVAL_MS=600000

# --- Cloudflare R2 (큰 산출물 다운로드를 presigned URL redirect 로 우회 → egress 비용 0)
# blank(R2_BUCKET 미설정) 이면 서버가 stem 을 직접 streaming (로컬 dev / R2 미사용 호환).
# vibi-bff 와 동일 계정/토큰 재사용 가능. 발급: Cloudflare dashboard → R2 → Manage API Tokens
# → Object Read & Write. R2_ACCOUNT_ID 는 dashboard URL(dash.cloudflare.com/<id>/r2) 의 32자 hex.
# 같은 버킷을 bff 와 공유해도 key prefix(separation/, dub/)가 달라 충돌 없음.
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# presigned URL TTL(초). 60..86400. 클라가 status 응답 직후 다운로드한다는 가정. 기본 3600.
SIGNED_URL_TTL_SEC=3600

# --- Perso (separation engine) — compose 가 BASE 값 주입하므로 키만 채우면 됨.
PERSO_API_KEY=
PERSO_SPACE_SEQ=

# --- Paddle Billing (credit top-up) — 승인/라이브 후 production 으로.
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
# Webhook 대상 URL 은 https://plugin-api.vibi.fm 의 Paddle 라우트로 등록.
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_STARTER=
PADDLE_PRICE_PRO=
PADDLE_PRICE_STUDIO=
PADDLE_CURRENCY=usd

# --- Caddy ACME (옵션) — Let's Encrypt 만료 알림 받을 이메일. 비워도 발급은 정상.
ACME_EMAIL=
