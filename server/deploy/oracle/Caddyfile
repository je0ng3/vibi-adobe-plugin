# Caddy 2 — 자동 HTTPS(Let's Encrypt) + server:8787 리버스 프록시.
# 도메인 A 레코드가 이 VM 의 public IP 를 가리키면 Caddy 가 부팅 시 인증서를 알아서 발급/갱신.

{
	# ACME 만료 알림 이메일 — gitignored plugin.env 의 ACME_EMAIL 로 주입 (커밋에 개인정보 안 남김).
	# 미설정이어도 Let's Encrypt 발급은 정상 동작 (만료 알림만 못 받음).
	email {$ACME_EMAIL}
}

# 도메인은 공개 정보라 커밋. 플러그인 manifest 의 network 도메인 / 빌드 VIBI_BFF_BASE_URL 과 동일.
plugin-api.vibi.fm {
	reverse_proxy server:8787

	# 업로드 상한. /mix 의 앱 한도(MAX_TOTAL_BYTES=400MB)와 맞춤 — 더 낮으면 mix 가 Caddy 에서
	# 잘림. 나머지 라우트는 앱에서 200MB 로 더 빡빡하게 막으므로 이 값은 천장 역할.
	# Caddy 는 기본 스트리밍(버퍼 0)이라 이 상한까지 메모리 부담 없음.
	request_body {
		max_size 400MB
	}

	# 텍스트/JSON 응답만 gzip. 오디오 바이너리(audio/wav: 스템·믹스 다운로드)는 압축 제외 —
	# UXP 의 fetch 는 gzip 으로 인코딩된(그리고 Content-Length 없이 chunked 로 오는) 바이너리
	# 본문을 끝까지 읽지 못해 arrayBuffer() 가 영영 멈춘다(throw 도 안 함). 결과: 분리는 ready 인데
	# 스템 다운로드가 행 → "완료됐는데 결과 안 뜸". WAV 는 gzip 이득도 거의 없어 제외가 맞다.
	encode {
		gzip
		match {
			header Content-Type text/*
			header Content-Type application/json*
		}
	}
}
